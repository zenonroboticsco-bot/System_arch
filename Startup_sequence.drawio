        <mxCell id="s0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;overflow=hidden;fillColor=#263238;gradientColor=#37474F;gradientDirection=south;fontColor=#FFFFFF;strokeColor=#FFFFFF66;strokeWidth=1.5;fontStyle=1;fontSize=10;shadow=1;align=center;verticalAlign=middle;" value="&lt;font style=&quot;font-size: 22px;&quot;&gt;▶  bash run.sh&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="680" x="80" y="60" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;overflow=hidden;fillColor=#1A3A2F;gradientColor=#2E7D32;gradientDirection=south;fontColor=#FFFFFF;strokeColor=#FFFFFF66;strokeWidth=1.5;fontStyle=1;fontSize=10;shadow=1;align=center;verticalAlign=middle;" value="&lt;font style=&quot;font-size: 17px;&quot;&gt;STEP 1 — Audio Routing&lt;br&gt;pactl: USB speaker as default sink&lt;br&gt;pactl: ReSpeaker as source · volume 30%&lt;/font&gt;" vertex="1">
          <mxGeometry height="77" width="680" x="79" y="163" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;overflow=hidden;fillColor=#0D2B55;gradientColor=#1565C0;gradientDirection=south;fontColor=#FFFFFF;strokeColor=#FFFFFF66;strokeWidth=1.5;fontStyle=1;fontSize=10;shadow=1;align=center;verticalAlign=middle;" value="&lt;font style=&quot;font-size: 15px;&quot;&gt;STEP 2 — Environment Setup&lt;br&gt;source /opt/ros/humble/setup.bash&lt;br&gt;source ~/robin_ws/install/setup.bash&lt;br&gt;Detect DISPLAY=:0·XAUTHORITY·CUDA&lt;/font&gt;" vertex="1">
          <mxGeometry height="82.5" width="674.5" x="80" y="280" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;overflow=hidden;fillColor=#7C0A02;gradientColor=#C62828;gradientDirection=south;fontColor=#FFFFFF;strokeColor=#FFFFFF66;strokeWidth=1.5;fontStyle=1;fontSize=10;shadow=1;align=center;verticalAlign=middle;" value="&lt;font style=&quot;font-size: 17px;&quot;&gt;STEP 3 — Kill Stale Processes&lt;br&gt;pkill -9: camera·face_recognition&lt;br&gt;pkill -9: wake_listener·scan_mode&lt;br&gt;Kill old ros2 launch (SIGINT)&lt;/font&gt;" vertex="1">
          <mxGeometry height="85" width="680" x="80" y="402" as="geometry" />
        </mxCell>
        <mxCell id="s4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;overflow=hidden;fillColor=#311B92;gradientColor=#7B1FA2;gradientDirection=south;fontColor=#FFFFFF;strokeColor=#FFFFFF66;strokeWidth=1.5;fontStyle=1;fontSize=10;shadow=1;align=center;verticalAlign=middle;" value="&lt;font style=&quot;font-size: 15px;&quot;&gt;STEP 4 — Reset ROS Daemon&lt;br&gt;ros2 daemon stop→pkill ros2cli.daemon&lt;br&gt;sleep 2→ros2 daemon start&lt;br&gt;Prevents rclpy.ok() XMLRPC faults&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="680" x="80" y="530" as="geometry" />
        </mxCell>
        <mxCell id="s5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;overflow=hidden;fillColor=#7B1314;gradientColor=#C62828;gradientDirection=south;fontColor=#FFFFFF;strokeColor=#FFFFFF66;strokeWidth=1.5;fontStyle=1;fontSize=10;shadow=1;align=center;verticalAlign=middle;" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;STEP 5 — Start Camera Node&lt;br&gt;python3 camera_publisher_node.py &amp;amp;&lt;br&gt;sleep 6→lifecycle configure→activate&lt;br&gt;Verify: ros2 topic hz&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="680" x="74.5" y="818" as="geometry" />
        </mxCell>
        <mxCell id="s6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;overflow=hidden;fillColor=#0D2B55;gradientColor=#1565C0;gradientDirection=south;fontColor=#FFFFFF;strokeColor=#FFFFFF66;strokeWidth=1.5;fontStyle=1;fontSize=10;shadow=1;align=center;verticalAlign=middle;" value="&lt;font style=&quot;font-size: 15px;&quot;&gt;STEP 6 — Main Robot Stack&lt;br&gt;ros2 launch robot_interface robot_interface.launch.py &amp;amp;&lt;br&gt;Launches: wake_listener·face_node·node_manager&lt;br&gt;api_server·mic_array·dxl nodes&lt;/font&gt;" vertex="1">
          <mxGeometry height="88" width="680" x="90" y="980" as="geometry" />
        </mxCell>
        <mxCell id="n_warn" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;overflow=hidden;fillColor=#7C0A02;gradientColor=#C62828;gradientDirection=south;fontColor=#FFFFFF;strokeColor=#FFFFFF66;strokeWidth=1.5;fontStyle=1;fontSize=10;shadow=1;align=center;verticalAlign=middle;" value="&lt;font style=&quot;font-size: 17px;&quot;&gt;⚠  Camera silent&lt;br&gt;Check ribbon cable&lt;br&gt;Restart nvargus-daemon&lt;br&gt;Continue anyway&lt;/font&gt;" vertex="1">
