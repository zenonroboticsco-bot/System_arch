        <mxCell id="bg_par" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;overflow=hidden;fillColor=#263238;gradientColor=#37474F;gradientDirection=south;fontColor=#FFFFFF;strokeColor=#FFFFFF66;strokeWidth=1.5;fontStyle=1;fontSize=12;shadow=1;align=center;verticalAlign=middle;" value="&lt;font style=&quot;font-size: 19px;&quot;&gt;PARALLEL DELAYED STARTS (background subshells)&lt;/font&gt;" vertex="1">
