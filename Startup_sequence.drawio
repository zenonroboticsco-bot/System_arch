        <mxCell id="p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;overflow=hidden;fillColor=#7B1314;gradientColor=#C62828;gradientDirection=south;fontColor=#FFFFFF;strokeColor=#FFFFFF66;strokeWidth=1.5;fontStyle=1;fontSize=9;shadow=1;align=center;verticalAlign=middle;" value="&lt;font style=&quot;font-size: 15px;&quot;&gt;STEP 7 — face_recognition&lt;br&gt;sleep 10s&lt;br&gt;python3 face_recognition_node.py&lt;br&gt;-p greeting_cooldown:=600&lt;br&gt;-p db_path:=face_profiles.db&lt;br&gt;sleep 6→configure→activate&lt;/font&gt;" vertex="1">
